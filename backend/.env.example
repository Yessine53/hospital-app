# ---------------------------------------------------------------------------
# This file is for running the backend WITHOUT Docker (local Node directly).
# When using docker-compose, env vars are injected from the project-root .env
# instead — see ../.env.example.
#
# Copy this file to .env (in the backend/ directory) and fill in real values.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=5000

# Use your local MongoDB or MongoDB Atlas connection string
MONGODB_URI=mongodb://<user>:<password>@localhost:27017/hospital_db?authSource=admin

# Generate with:  openssl rand -base64 48
JWT_SECRET=<generate-a-strong-secret>
JWT_EXPIRES_IN=7d

ML_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Phase 2 (delivery layer not yet wired up) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
