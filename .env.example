# ---------------------------------------------------------------------------
# Copy this file to .env (in the project root) and fill in real values.
# .env is gitignored — never commit it.
#
#   cp .env.example .env
#   # then edit .env
#
# Then run:
#   docker compose up --build -d
# ---------------------------------------------------------------------------

# --- Environment ---
NODE_ENV=development

# --- MongoDB (used by docker-compose to bootstrap the mongo container) ---
MONGO_USER=admin
MONGO_PASSWORD=change-me-please
MONGO_DB=hospital_db

# --- JWT ---
# Generate a strong secret with:  openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-from-openssl-rand
JWT_EXPIRES_IN=7d

# --- Frontend URL (for backend CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Frontend API URL (baked into the Vite build) ---
VITE_API_URL=http://localhost:5000/api

# --- Email delivery (Phase 2 — not yet wired into the reminder dispatcher) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# --- SMS delivery (Phase 2) ---
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
